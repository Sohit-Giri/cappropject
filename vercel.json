{
  "version": 2,
  "builds": [
    { "src": "backend/core/wsgi.py", "use": "@vercel/python" },
    { "src": "backend/staticfiles/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/backend/staticfiles/$1" },
    { "src": "/(.*)",        "dest": "backend/core/wsgi.py"    }
  ]
}
